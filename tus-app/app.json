{
  "expo": {
    "name": "TUS Hazırlık",
    "slug": "tus-prep-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1A3C5E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tushazirlik.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A3C5E"
      },
      "package": "com.tushazirlik.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-linear-gradient"
    ]
  }
}
